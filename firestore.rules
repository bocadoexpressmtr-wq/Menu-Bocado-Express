rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "enamoradooluis@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Categories: Publicly readable, admin writable
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Products: Publicly readable, admin writable
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders: Admin can read all, anyone can create, only admin can update/delete
    match /orders/{orderId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Users: Only admin can manage
    match /users/{userId} {
      allow read, write: if isAdmin();
    }

    // Settings: Publicly readable (for store status), admin writable
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Customers: Publicly readable/writable for loyalty program (phone-based)
    match /customers/{customerId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }

    // Reviews: Publicly readable/creatable, admin manageable
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Feedback: Anyone can create, only admin can read/manage
    match /feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Coupons: Publicly readable for validation, admin writable
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
