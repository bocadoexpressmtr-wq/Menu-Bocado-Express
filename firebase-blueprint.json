{
  "entities": {
    "Category": {
      "title": "Category",
      "description": "A category for menu items (e.g., Hamburgers, Drinks)",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the category"
        },
        "order": {
          "type": "number",
          "description": "Display order"
        }
      },
      "required": ["name", "order"]
    },
    "Product": {
      "title": "Product",
      "description": "A menu item",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the product"
        },
        "description": {
          "type": "string",
          "description": "Description of the product"
        },
        "price": {
          "type": "number",
          "description": "Price of the product"
        },
        "imageUrl": {
          "type": "string",
          "description": "URL of the product image"
        },
        "categoryId": {
          "type": "string",
          "description": "ID of the category this product belongs to"
        },
        "isAvailable": {
          "type": "boolean",
          "description": "Whether the product is currently available"
        },
        "isPopular": {
          "type": "boolean",
          "description": "Whether the product is a top seller"
        },
        "isDailyOffer": {
          "type": "boolean",
          "description": "Whether the product is a daily offer"
        },
        "isUpsell": {
          "type": "boolean",
          "description": "Whether the product is an upsell item (e.g., drinks, extras)"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tags like 'Nuevo', 'Recomendado'"
        }
      },
      "required": ["name", "price", "categoryId", "isAvailable"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "customerName": {
          "type": "string",
          "description": "Name of the customer"
        },
        "customerPhone": {
          "type": "string",
          "description": "Phone number of the customer"
        },
        "customerAddress": {
          "type": "string",
          "description": "Delivery address"
        },
        "deliveryType": {
          "type": "string",
          "enum": ["domicilio", "recoger", "local"],
          "description": "Type of delivery"
        },
        "paymentMethod": {
          "type": "string",
          "enum": ["nequi", "efectivo"],
          "description": "Payment method"
        },
        "cashAmount": {
          "type": "number",
          "description": "Amount the customer will pay with in cash"
        },
        "loyaltyOptIn": {
          "type": "boolean",
          "description": "Whether the customer opted into the loyalty program"
        },
        "pointsGranted": {
          "type": "boolean",
          "description": "Whether points have been granted for this order"
        },
        "referredBy": {
          "type": "string",
          "description": "Phone number of the referrer"
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            },
            "required": ["productId", "name", "quantity", "price"]
          },
          "description": "Items in the order"
        },
        "totalAmount": {
          "type": "number",
          "description": "Total amount of the order"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "confirmed", "preparing", "delivering", "completed", "cancelled", "archived"],
          "description": "Status of the order"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the order was created"
        },
        "notes": {
          "type": "string",
          "description": "Order notes"
        }
      },
      "required": ["customerName", "customerPhone", "deliveryType", "paymentMethod", "items", "totalAmount", "status", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "An admin user",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email of the user"
        },
        "role": {
          "type": "string",
          "enum": ["admin"],
          "description": "Role of the user"
        }
      },
      "required": ["email", "role"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global store settings",
      "type": "object",
      "properties": {
        "isStoreOpen": {
          "type": "boolean",
          "description": "Whether the store is currently accepting orders"
        },
        "loyaltyPrize": {
          "type": "string",
          "description": "The prize for reaching the loyalty goal"
        },
        "loyaltyGoal": {
          "type": "number",
          "description": "Number of stamps required for the prize"
        },
        "referralEnabled": {
          "type": "boolean",
          "description": "Whether the referral program is active"
        }
      },
      "required": ["isStoreOpen", "loyaltyPrize", "loyaltyGoal", "referralEnabled"]
    },
    "Customer": {
      "title": "Customer",
      "description": "A loyalty program customer",
      "type": "object",
      "properties": {
        "phone": {
          "type": "string",
          "description": "Phone number (used as ID)"
        },
        "name": {
          "type": "string",
          "description": "Name of the customer"
        },
        "lastUsedAddress": {
          "type": "string",
          "description": "Last delivery address used"
        },
        "stamps": {
          "type": "number",
          "description": "Number of accumulated stamps"
        },
        "referredBy": {
          "type": "string",
          "description": "Phone number of the referrer"
        },
        "totalOrders": {
          "type": "number",
          "description": "Total number of completed orders"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the customer joined"
        }
      },
      "required": ["phone", "name", "stamps", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "A customer review",
      "type": "object",
      "properties": {
        "customerName": {
          "type": "string",
          "description": "Name of the customer"
        },
        "text": {
          "type": "string",
          "description": "Review text"
        },
        "rating": {
          "type": "number",
          "description": "Rating out of 5"
        },
        "isVisible": {
          "type": "boolean",
          "description": "Whether the review is visible on the menu"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the review was created"
        }
      },
      "required": ["customerName", "text", "rating", "isVisible", "createdAt"]
    }
  },
  "firestore": {
    "categories": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Categories for the menu"
    },
    "products": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Products in the menu"
    },
    "orders": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Customer orders"
    },
    "users": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Admin users"
    },
    "settings": {
      "schema": { "$ref": "#/entities/Settings" },
      "description": "Global store settings (usually a single document 'store')"
    },
    "customers": {
      "schema": { "$ref": "#/entities/Customer" },
      "description": "Loyalty program customers"
    },
    "reviews": {
      "schema": { "$ref": "#/entities/Review" },
      "description": "Customer reviews"
    }
  }
}
